# ============================================================
# Evangelion
# ------------------------------------------------------------
# EVA-01 Purple, Neon Green, and Dark Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="evangelion"
GTK_THEME="Evangelion"
ICON_THEME="Fluent-purple-dark"
GTK_CSS="$HOME/.config/i3/themes/evangelion/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/evangelion/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/evangelion/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/evangelion.png"
CALCURSE_THEME="green"
BTOP_THEME="evangelion"


# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="EVANGELION_THEME.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/evangelion/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="evangelion.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#1a1a2e"							# deep dark navy purple
DUNST_FG="#e8e8f0"							# off white
DUNST_FRAME="#39ff14"						# neon green
DUNST_LOW_BG="#0d0d1a"						# near black purple
DUNST_LOW_FG="#7a6b8a"						# muted purple grey
DUNST_LOW_FRAME="#4a3060"					# dark purple
DUNST_CRITICAL_BG="#ff4500"					# EVA warning orange-red
DUNST_CRITICAL_FG="#e8e8f0"				# off white
DUNST_CRITICAL_FRAME="#ff6a00"				# bright orange
DUNST_FONT="JetBrainsMono Nerd Font 10"	# Nerd Fonts




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=1a1a2ecc        	# deep dark navy purple
LOCK_RING=39ff14ff          	# neon green
LOCK_KEY=7b2d8bff           	# EVA purple
LOCK_BACKSPACE=ff4500ff     	# warning orange-red
LOCK_VER=39ff14ff           	# neon green
LOCK_VER_RING=39ff14ff			# neon green
LOCK_WRONG=ff4500ff				# warning orange-red
LOCK_WRONG_RING=ff4500ff		# warning orange-red
LOCK_TIME=e8e8f0ff          	# off white
LOCK_DATE=c8c0d8ff          	# pale purple white
LOCK_LAYOUT=e8e8f0ff        	# off white
LOCK_SEPARATOR=00000000			# flat black
LOCK_LINE=00000000				# flat black
LOCK_TEXT=e8e8f0ff				# off white
LOCK_RINGCLEAR=7b2d8bff     	# EVA purple
LOCK_INSIDECLEAR=1a1a2ecc		# deep dark navy purple
LOCK_BG=0d0d1aff				# near black purple
LOCK_BLUR="0x12"				# blur intensity
