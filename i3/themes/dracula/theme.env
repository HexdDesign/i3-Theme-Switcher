# ============================================================
# Dracula
# ------------------------------------------------------------
# Pink, Purple, and Grey
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="dracula"
GTK_THEME="Dracula"
ICON_THEME="Tela-circle-dracula"
GTK_CSS="$HOME/.config/i3/themes/dracula/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/dracula/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/dracula/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/dracula.png"
CALCURSE_THEME="magenta"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================
GEANY_SCHEME="Hexd-Dracula.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/dracula/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="dracula.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#282a36"						# pale grey blue
DUNST_FG="#f8f8f2"						# near white
DUNST_FRAME="#bd93f9"					# neon purple
DUNST_LOW_BG="#21222c"					# dark grey blue
DUNST_LOW_FG="#6272a4"					# pale slate blue
DUNST_LOW_FRAME="#8be9fd"				# bright cyan
DUNST_CRITICAL_BG="#ff5555"				# bright orange
DUNST_CRITICAL_FG="#f8f8f2"				# near white
DUNST_CRITICAL_FRAME="#ff79c6"			# neon pink
DUNST_FONT="JetBrainsMono Nerd Font 10"



# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=282a36cc					# dark blue grey
LOCK_RING=bd93f9ff						# neon violet
LOCK_KEY=ff79c6ff						# neon pink
LOCK_BACKSPACE=ff5555ff					# bright orange pink
LOCK_VER=50fa7bff						# lime green
LOCK_VER_RING=50fa7bff					# lime green
LOCK_WRONG=ff5555ff						# bright orange pink
LOCK_WRONG_RING=ff5555ff				# bright orange pink
LOCK_TIME=f8f8f2ff						# near white 
LOCK_DATE=f8f8f2ff						# near white
LOCK_LAYOUT=f8f8f2ff					# near white
LOCK_BLUR="0x12"						# blur intensity
