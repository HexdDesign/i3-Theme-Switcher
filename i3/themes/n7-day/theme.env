# ============================================================
# N7 Day
# ------------------------------------------------------------
# Violet and Magenta N7 Mass Effect Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="n7-day"
GTK_THEME="N7Day"
ICON_THEME="Gradient-Dark-Icons"
GTK_CSS="$HOME/.config/i3/themes/n7-day/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/n7-day/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/n7-day/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/n7-day.png"
CALCURSE_THEME="magenta"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="N7DAY_THEME.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/n7-day/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="n7-day.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#0d0a10"					# dark violet
DUNST_FG="#f0dde0"					# pale pink white
DUNST_FRAME="#c41e3a"				# bright red
DUNST_LOW_BG="#100810"				# dark violet
DUNST_LOW_FG="#7a4a5e"				# pale violet
DUNST_LOW_FRAME="#3a1428"			# maroon violet
DUNST_CRITICAL_BG="#ff2244"			# bright red
DUNST_CRITICAL_FG="#f0dde0"			# pale pink white
DUNST_CRITICAL_FRAME="#ff6090"		# bright pink
DUNST_FONT="JetBrainsMono Nerd Font 10"




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0d0a0ecc        # near black
LOCK_RING=e8192cff          # crimson
LOCK_KEY=d4cfe0ff           # silver white
LOCK_KEYHL=d4cfe0ff         # silver white
LOCK_BACKSPACE=e8820aff     # ember gold
LOCK_BSHL=e8820aff          # ember gold
LOCK_VER=5a1a2aff           # dark crimson
LOCK_VER_RING=5a1a2aff		# dark crimson
LOCK_RING_VER=5a1a2aff      # dark crimson
LOCK_WRONG=e8820aff         # ember gold
LOCK_WRONG_RING=e8820aff	# ember gold
LOCK_RING_WRONG=e8820aff    # ember gold
LOCK_TIME=d4cfe0ff          # silver white
LOCK_TIME_COLOR=d4cfe0ff    # silver white
LOCK_DATE=a09aacff          # muted silver
LOCK_DATE_COLOR=a09aacff    # muted silver
LOCK_LAYOUT=d4cfe0ff		# silver white
LOCK_LAYOUT_COLOR=d4cfe0ff  # silver white
LOCK_VERIF_COLOR=5a1a2aff   # silver white
LOCK_WRONG_COLOR=e8820aff   # silver white
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=d4cfe0ff			# silver white
LOCK_RINGCLEAR=5a1a2aff     # dark crimson
LOCK_INSIDECLEAR=0d0a0ecc	# near black
LOCK_BG=0d0a0e              # near black
LOCK_BLUR="0x12"			# blur intensity

