# ============================================================
# Project Hail Mary
# ------------------------------------------------------------
# Black, yellow, and some grey and blue tones
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="project-hail-mary"
GTK_THEME="Project-Hail-Mary"
ICON_THEME="Iceglass-4.12"
GTK_CSS="$HOME/.config/i3/themes/project-hail-mary/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/project-hail-mary/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/project-hail-mary/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/project-hail-mary.png"
CALCURSE_THEME="yellow"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="PROJECT_HAIL_MARY.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/project-hail-mary/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="project-hail-mary.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#182938"							# near black
DUNST_FG="#E0DCD6"							# off white
DUNST_FRAME="#C8A75B"						# yellow
DUNST_LOW_BG="#182938"						# near black
DUNST_LOW_FG="#E0DCD6"						# off white
DUNST_LOW_FRAME="#BEBBB4"					# grey
DUNST_CRITICAL_BG="#813139"					# red
DUNST_CRITICAL_FG="#E0DCD6"					# off white
DUNST_CRITICAL_FRAME="#BF6767"				# orange
DUNST_FONT="JetBrainsMono Nerd Font 10"		# Nerd Fonts




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0d1628cc        	# deep navy (badge background)
LOCK_RING=c8a020ff          	# gold (border ring)
LOCK_KEY=e8c060ff           	# warm gold (sun glow)
LOCK_BACKSPACE=8b1a1aff     	# dark crimson (ribbon)
LOCK_VER=c8a020ff           	# gold (border ring)
LOCK_VER_RING=e8c060ff			# warm gold (sun glow)
LOCK_WRONG=8b1a1aff				# dark crimson (ribbon)
LOCK_WRONG_RING=8b1a1aff		# dark crimson (ribbon)
LOCK_TIME=e8e8f0ff          	# near white (rocket tubes)
LOCK_DATE=e8c060ff          	# warm gold (sun glow)
LOCK_LAYOUT=e8e8f0ff        	# near white (rocket tubes)
LOCK_SEPARATOR=00000000			# transparent
LOCK_LINE=00000000				# transparent
LOCK_TEXT=e8e8f0ff				# near white (rocket tubes)
LOCK_RINGCLEAR=4a7ab8ff     	# steel blue (ship body)
LOCK_INSIDECLEAR=0d1628cc		# deep navy (badge background)
LOCK_BG=0d1628ff				# deep navy (badge background)
LOCK_BLUR="0x12"				# blur intensity
