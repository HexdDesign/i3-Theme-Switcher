
# ============================================================
# Sakura Hunter
# ------------------------------------------------------------
# Monster Hunter Theme in Sakura Colors
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="sakura-hunter"
GTK_THEME="sakura-hunter"
ICON_THEME="Tela-circle-pink"
GTK_CSS="$HOME/.config/i3/themes/sakura-hunter/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/sakura-hunter/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/sakura-hunter/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/Sakura.png"
CALCURSE_THEME="white"
BTOP_THEME="sakura-hunter"


# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="SAKURA_HUNTER.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/sakura-hunter/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="sakura-hunter.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#1a0f1a"						# dark violet
DUNST_FG="#f0e6ec"						# white pink
DUNST_FRAME="#e8a0c0"					# pink
DUNST_LOW_BG="#2a1e2a"					# violet
DUNST_LOW_FG="#a07890"					# pale silver violet
DUNST_LOW_FRAME="#3d2a3d"				# violet
DUNST_CRITICAL_BG="#c85a5a"				# pale red
DUNST_CRITICAL_FG="#f0e6ec"				# white pink violet
DUNST_CRITICAL_FRAME="#d4a855"			# gold
DUNST_FONT="JetBrainsMono Nerd Font 10"




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=1a0f1acc        # dark violet
LOCK_RING=e8a0c0ff          # pink
LOCK_KEY=5a8ab0ff           # light blue
LOCK_BACKSPACE=c85a5aff     # red
LOCK_VER=d4a855ff           # gold
LOCK_VER_RING=d4a855ff		# gold
LOCK_WRONG=c85a5aff			# light pink
LOCK_WRONG_RING=c85a5aff	# light pink
LOCK_TIME=f0e6ecff          # warm white
LOCK_DATE=c8a0b4ff          # light pink
LOCK_LAYOUT=f0e6ecff		# warm white
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=f0e6ecff			# warm white
LOCK_RINGCLEAR=5a8ab0ff     # light blue
LOCK_INSIDECLEAR=1a0f1acc	# dark violet
LOCK_BG=1a0f1aff			# dark violet
LOCK_BLUR="0x12"			# blur intensity

