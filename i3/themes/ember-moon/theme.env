# ============================================================
# Ember - Moon
# ------------------------------------------------------------
# Black Orange and Pink Katana Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="ember-moon"
GTK_THEME="ember-moon.conf" 
ICON_THEME="Slot-Silvery-Dark-Icons"  
GTK_CSS="$HOME/.config/i3/themes/ember-moon/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/ember-moon/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/ember-moon/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/ember-moon.png"
CALCURSE_THEME="red"
BTOP_THEME="ember-moon"


# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="EMBER_MOON.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/ember-moon/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="ember-moon.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#141417"						# dark blue
DUNST_FG="#C9CED6"						# light blue
DUNST_FRAME="#FF4D88"					# neon pink red
DUNST_LOW_BG="#1C1F26"					# dark blue black
DUNST_LOW_FG="#7E8794"					# pale violet blue
DUNST_LOW_FRAME="#FF7AA2"				# bright pink
DUNST_CRITICAL_BG="#E10600"				# bright blood red
DUNST_CRITICAL_FG="#FFFFFF"				# flat black
DUNST_CRITICAL_FRAME="#F4B942"			# pale yellow
DUNST_FONT="JetBrainsMono Nerd Font 10"



# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=141417cc        # near black 
LOCK_RING=FF4D88ff          # neon pink
LOCK_KEY=F4B942ff           # gold
LOCK_BACKSPACE=E10600ff     # ember red
LOCK_VER=F4B942ff           # gold
LOCK_VER_RING=F4B942ff		# gold
LOCK_WRONG=E10600ff			# red
LOCK_WRONG_RING=E10600ff	# red
LOCK_TIME=C9CED6ff          # warm white
LOCK_DATE=7E8794ff          # pale yellow
LOCK_LAYOUT=C9CED6ff		# warm white
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=C9CED6ff			# warm white 
LOCK_RINGCLEAR=FF7AA2ff     # soft pink
LOCK_INSIDECLEAR=141417cc	# near black
LOCK_BG=141417ff			# near black
LOCK_BLUR="0x12"			# blur intensity

