# ============================================================
# Blue - Yellow
# ------------------------------------------------------------
# Blue and Yellow Y2K Anime Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="chill"
ICON_THEME="Goldy-Dark-Icons"
GTK_CSS="$HOME/.config/i3/themes/chill/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/chill/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/chill/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/chill.png"
CALCURSE_THEME="white"
BTOP_THEME="chill"


# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="Hexd-Chill.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/chill/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="chill.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#0c0f24"							# dark navy blue
DUNST_FG="#e7ecf5"							# light silver blue
DUNST_FRAME="#bb865e"						# pale orange brown 
DUNST_LOW_BG="#19243a"						# dark navy blue
DUNST_LOW_FG="#9aa5b8"						# light silver blue
DUNST_LOW_FRAME="#233647"					# dark blue silver
DUNST_CRITICAL_BG="#3b2a2a"					# dark maroon red
DUNST_CRITICAL_FG="#ffe9d8"					# light yellow 
DUNST_CRITICAL_FRAME="#daa16c"				# light brown 
DUNST_FONT="JetBrainsMono Nerd Font 10"




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0c0f24cc						# light green
LOCK_RING=bb865eff							# orange brown
LOCK_KEY=daa16cff							# orange brown
LOCK_BACKSPACE=b86a6aff						# pale red
LOCK_VER=6fa38eff							# pale green
LOCK_VER_RING=6fa38eff						# pale green
LOCK_WRONG=b86a6aff							# pale red
LOCK_WRONG_RING=b86a6aff					# pale red
LOCK_TIME=e7ecf5ff							# silver white
LOCK_DATE=e7ecf5ff							# silver white 
LOCK_LAYOUT=e7ecf5ff						# silver white
LOCK_BLUR="0x12"							# blur intensity
