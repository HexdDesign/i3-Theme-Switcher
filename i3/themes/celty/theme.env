# ============================================================
# Celty — Durarara
# ------------------------------------------------------------
# Monochrome. No color.
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="celty"
GTK_THEME="Celty"
ICON_THEME="Avalon-Icons"
GTK_CSS="$HOME/.config/i3/themes/celty/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/celty/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/celty/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/celty.png"
CALCURSE_THEME="black"
BTOP_THEME="celty"


# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="CELTY_THEME.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/celty/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="celty.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#0d0d0d"						# black
DUNST_FG="#f0f0f0"						# almost white
DUNST_FRAME="#c8c8c8"					# light grey
DUNST_LOW_BG="#111111"					# near black
DUNST_LOW_FG="#666666"					# neutral grey
DUNST_LOW_FRAME="#333333"				# dark grey
DUNST_CRITICAL_BG="#ffffff"				# white
DUNST_CRITICAL_FG="#0d0d0d"				# black
DUNST_CRITICAL_FRAME="#f0f0f0"			# light white grey
DUNST_FONT="JetBrainsMono Nerd Font 10"



# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0d0d0dcc        # near black
LOCK_RING=c8c8c8ff          # light grey
LOCK_KEY=888888ff           # mid grey
LOCK_BACKSPACE=444444ff     # dark grey
LOCK_VER=f0f0f0ff           # near white
LOCK_VER_RING=f0f0f0ff		# near white
LOCK_WRONG=ffffffff         # white
LOCK_WRONG_RING=ffffffff	# white 
LOCK_TIME=f0f0f0ff			# near white 
LOCK_DATE=aaaaааff			# neutral grey
LOCK_LAYOUT=f0f0f0ff		# near white
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=f0f0f0ff			# near white
LOCK_RINGCLEAR=555555ff		# dark grey
LOCK_INSIDECLEAR=0d0d0dcc	# near black
LOCK_BG=0d0d0dff			# near black
LOCK_BLUR="0x14"			# blur intensity

