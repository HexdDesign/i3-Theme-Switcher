# ============================================================
# Purple Plastic
# ------------------------------------------------------------
# Electric Purple + Neon Green Theme
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="purple-plastic"
GTK_THEME="purple-plastic"
ICON_THEME="Vivid-Glassy-Dark-Icons"
GTK_CSS="$HOME/.config/i3/themes/purple-plastic/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/purple-plastic/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/purple-plastic/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/purple-plastic.png"
CALCURSE_THEME="green"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="PURPLE_PLASTIC.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/purple-plastic/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="purple-plastic.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#1a1533"							# deep purple black
DUNST_FG="#e8e0ff"							# pale lavender white
DUNST_FRAME="#39ff14"						# neon green
DUNST_LOW_BG="#0f0d1e"						# near black purple
DUNST_LOW_FG="#7b6fcf"						# muted purple
DUNST_LOW_FRAME="#2d2650"					# dark purple grey
DUNST_CRITICAL_BG="#ff3f6c"				# hot pink red
DUNST_CRITICAL_FG="#e8e0ff"				# pale lavender white
DUNST_CRITICAL_FRAME="#ff9f1c"				# orange
DUNST_FONT="JetBrainsMono Nerd Font 10"	# Nerd Fonts




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=1a1533cc        	# deep purple black
LOCK_RING=39ff14ff          	# neon green
LOCK_KEY=5b4effff           	# electric purple
LOCK_BACKSPACE=ff3f6cff     	# hot pink red
LOCK_VER=00ffb3ff           	# neon mint
LOCK_VER_RING=00ffb3ff			# neon mint
LOCK_WRONG=ff3f6cff				# hot pink red
LOCK_WRONG_RING=ff3f6cff		# hot pink red
LOCK_TIME=e8e0ffff          	# pale lavender
LOCK_DATE=c4b5fdff          	# light purple
LOCK_LAYOUT=e8e0ffff        	# pale lavender
LOCK_SEPARATOR=00000000			# flat black
LOCK_LINE=00000000				# flat black
LOCK_TEXT=e8e0ffff				# pale lavender
LOCK_RINGCLEAR=5b4effff     	# electric purple
LOCK_INSIDECLEAR=1a1533cc		# deep purple black
LOCK_BG=1a1533ff				# deep purple black
LOCK_BLUR="0x12"				# blur intensity
