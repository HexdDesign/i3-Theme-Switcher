# ============================================================
# Neon-Violet
# ------------------------------------------------------------
# Neon Violet Theme with Pink Accents
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="neon-violet"
GTK_THEME="Neon-violet"         
ICON_THEME="Vivid-Glassy-Dark-Icons" 
GTK_CSS="$HOME/.config/i3/themes/neon-violet/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/neon-violet/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/neon-violet/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/neon-violet.png"
CALCURSE_THEME="magenta"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="NEON_VIOLET.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/neon-violet/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================
STARSHIP_CONFIG="neon-violet.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#201028"
DUNST_FG="#f8f2ff"
DUNST_FRAME="#7d3cbe"
DUNST_LOW_BG="#341745"
DUNST_LOW_FG="#a98db8"
DUNST_LOW_FRAME="#602da4"
DUNST_CRITICAL_BG="#2a0f2e"
DUNST_CRITICAL_FG="#f8f2ff"
DUNST_CRITICAL_FRAME="#c43799"
DUNST_FONT="JetBrainsMono Nerd Font 10"



# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=201028cc        # dark violet
LOCK_RING=e741bbff          # neon pink
LOCK_KEY=edb4ddff           # near white
LOCK_KEYHL=edb4ddff         # near white
LOCK_BACKSPACE=c43799ff     # magenta
LOCK_BSHL=c43799ff          # backspace highlight
LOCK_VER=7d3cbeff           # verifying violet
LOCK_VER_RING=7d3cbeff		# blue
LOCK_RING_VER=7d3cbeff		# blue
LOCK_WRONG=c43799ff         # red
LOCK_WRONG_RING=c43799ff 	# red
LOCK_RING_WRONG=c43799ff	# red
LOCK_TIME=f8f2ffff          # near white
LOCK_TIME_COLOR=f8f2ffff 	# near white
LOCK_DATE=edb4ddff			# near white
LOCK_DATE_COLOR=edb4ddff	# near white
LOCK_LAYOUT=f8f2ffff		# near white
LOCK_LAYOUT_COLOR=f8f2ffff  # near white
LOCK_VERIF_COLOR=7d3cbeff	# blue
LOCK_WRONG_COLOR=c43799ff	# red
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=f8f2ffff			# near white
LOCK_RINGCLEAR=7d3cbeff		# blue
LOCK_INSIDECLEAR=201028cc	# dark violet
LOCK_BG=201028              # near black
LOCK_BLUR="0x12"			# blur intensity

