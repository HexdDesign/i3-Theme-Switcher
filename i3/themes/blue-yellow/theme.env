# ============================================================
# Blue - Yellow
# ------------------------------------------------------------
# Blue and Yellow Y2K Anime Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="blue-yellow"
GTK_THEME="Blue-Yellow"
ICON_THEME="Fluent-yellow-dark"
GTK_CSS="$HOME/.config/i3/themes/blue-yellow/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/blue-yellow/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/blue-yellow/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/blue-yellow.png"
CALCURSE_THEME="yellow"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="BLUE_YELLOW.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/blue-yellow/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="blue-yellow.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#123d88"				# dark blue
DUNST_FG="#c2d9e8"				# pale baby blue
DUNST_FRAME="#ffd36a"			# dandelion yellow
DUNST_LOW_BG="#0d2d66"			# dark blue
DUNST_LOW_FG="#6c9bb3"			# pale slate blue
DUNST_LOW_FRAME="#09acf7"		# bright blue
DUNST_CRITICAL_BG="#ffd36a"		# pale yellow
DUNST_CRITICAL_FG="#0a1a3a"		# navy blue
DUNST_CRITICAL_FRAME="#ff5555"	# red 
DUNST_FONT="JetBrainsMono Nerd Font 10"




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0b1b3acc        # deep navy w/ alpha
LOCK_RING=ffd400ff          # vivid yellow
LOCK_KEY=4fc3f7ff           # bright sky-blue highlight
LOCK_BACKSPACE=ff5252ff     # red for destructive action
LOCK_VER=00e676ff           # green verify
LOCK_VER_RING=00e676ff		# lime green
LOCK_WRONG=ff5252ff			# red
LOCK_WRONG_RING=ff5252ff	# red
LOCK_TIME=eaf2ffff          # near-white
LOCK_DATE=bcd3ffff          # soft pale blue
LOCK_LAYOUT=ffd400ff        # match ring (yellow)
LOCK_SEPARATOR=00000000		# black		
LOCK_LINE=00000000			# black
LOCK_TEXT=eaf2ffff			# pale bright grey
LOCK_RINGCLEAR=4fc3f7ff		# light neon blue
LOCK_INSIDECLEAR=0b1b3acc	# light brown (clear)
LOCK_BG=0b1b3aff			# dark navy blue
LOCK_BLUR="0x12"			# blur intensity
