# ============================================================
# Digital Circus
# ------------------------------------------------------------
# Neon theme inspired by The Amazing Digital Circus
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="digital-circus"
GTK_THEME="Digital-Circus"
ICON_THEME="We10X-dark"
GTK_CSS="$HOME/.config/i3/themes/digital-circus/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/digital-circus/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/digital-circus/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/digital-circus.png"
CALCURSE_THEME="pink"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="DIGITAL_CIRCUS.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/digital-circus/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="digital-circus.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#0d0520"			# deep purple-black
DUNST_FG="#F5E6FF"			# pale lavender white
DUNST_FRAME="#FF2D9B"		# hot magenta pink
DUNST_LOW_BG="#1a0840"		# dark purple
DUNST_LOW_FG="#9966CC"		# muted violet
DUNST_LOW_FRAME="#00EEFF"	# electric cyan
DUNST_CRITICAL_BG="#FF2D9B"	# hot pink
DUNST_CRITICAL_FG="#0d0520"	# deep purple-black
DUNST_CRITICAL_FRAME="#FF6A00"	# neon orange
DUNST_FONT="JetBrainsMono Nerd Font 10"




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0d0520cc        # deep purple-black w/ alpha
LOCK_RING=FF2D9Bff          # hot magenta
LOCK_KEY=00EEFFff           # electric cyan highlight
LOCK_BACKSPACE=FF6A00ff     # neon orange for destructive action
LOCK_VER=39FF14ff           # acid green verify
LOCK_VER_RING=39FF14ff		# acid green
LOCK_WRONG=FF6A00ff			# neon orange
LOCK_WRONG_RING=FF6A00ff	# neon orange
LOCK_TIME=F5E6FFff          # pale lavender white
LOCK_DATE=CC99FFff          # soft violet
LOCK_LAYOUT=FF2D9Bff        # hot pink
LOCK_SEPARATOR=00000000		# transparent
LOCK_LINE=00000000			# transparent
LOCK_TEXT=F5E6FFff			# pale lavender white
LOCK_RINGCLEAR=00EEFFff		# electric cyan
LOCK_INSIDECLEAR=0d0520cc	# deep purple-black
LOCK_BG=0d0520ff			# deep purple-black
LOCK_BLUR="0x12"			# blur intensity
