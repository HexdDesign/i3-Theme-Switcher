# ============================================================
# EnA - Joel G.
# ------------------------------------------------------------
# EnA Dream BBQ Inspired Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="ena"
GTK_THEME="Ena"
ICON_THEME="Fluent-red"
GTK_CSS="$HOME/.config/i3/themes/ena/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/ena/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/ena/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/ena.png"
CALCURSE_THEME="red"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="ENA_THEME.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/ena/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="ena.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#1a0a0a"					# dark crimson red
DUNST_FG="#f0e6d6"					# warm yellow white
DUNST_FRAME="#c0303a"				# bright red
DUNST_LOW_BG="#110606"				# dark crimson red
DUNST_LOW_FG="#7a5a5a"				# pale red grey 
DUNST_LOW_FRAME="#4a2020"			# maroon red
DUNST_CRITICAL_BG="#d4583a"			# orange
DUNST_CRITICAL_FG="#f0e6d6"			# warm yellow white
DUNST_CRITICAL_FRAME="#e87050"		# orange
DUNST_FONT="JetBrainsMono Nerd Font 10"



# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=1a0a0acc        # near black
LOCK_RING=c0303aff          # red
LOCK_KEY=8b1a1aff           # dark red
LOCK_BACKSPACE=d4583aff     # orange
LOCK_VER=3d7a5aff           # teal 
LOCK_VER_RING=3d7a5aff		# teal
LOCK_WRONG=d4583aff			# orange 
LOCK_WRONG_RING=d4583aff	# orange
LOCK_TIME=f0e6d6ff          # cream white
LOCK_DATE=d8c8b0ff			# tan brown 
LOCK_LAYOUT=f0e6d6ff		# cream white
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=f0e6d6ff			# cream white
LOCK_RINGCLEAR=8b1a1aff		# red
LOCK_INSIDECLEAR=1a0a0acc	# near black
LOCK_BG=1a0a0aff			# near black
LOCK_BLUR="0x12"			# blur intensity

