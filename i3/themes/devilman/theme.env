# ============================================================
# Devilman
# ------------------------------------------------------------
# Devilman Crybaby Red and Black Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="devilman"
GTK_THEME="devilman"
ICON_THEME="Fluent-red-dark"
GTK_FONT="Hack Nerd Font 11"
CURSOR_THEME="volantes_cursors"
GTK_CSS="$HOME/.config/i3/themes/devilman/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/devilman/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/devilman/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/devilman.png"
CALCURSE_THEME="red"
BTOP_THEME="devilman"


# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="DEVILMAN.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/devilman/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="devilman.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#0d0a0e"							# dark violet 
DUNST_FG="#d4cfe0"							# light violet
DUNST_FRAME="#e8192c"						# red
DUNST_LOW_BG="#110d14"						# dark violet
DUNST_LOW_FG="#6a5a70"						# pale violet
DUNST_LOW_FRAME="#5a1a2a"					# dark crimson
DUNST_CRITICAL_BG="#3a0a10"					# dark crimson
DUNST_CRITICAL_FG="#d4cfe0"					# pale light violet
DUNST_CRITICAL_FRAME="#e8820a"				# bright orange
DUNST_FONT="JetBrainsMono Nerd Font 10"




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0d0a0ecc        # near black
LOCK_RING=e8192cff          # crimson accent
LOCK_KEY=d4cfe0ff           # silver-white
LOCK_KEYHL=d4cfe0ff         # key highlight
LOCK_BACKSPACE=e8820aff     # ember gold
LOCK_BSHL=e8820aff          # ember gold
LOCK_VER=5a1a2aff           # dark crimson
LOCK_VER_RING=5a1a2aff		# dark crimson
LOCK_RING_VER=5a1a2aff      # dark crimson
LOCK_WRONG=e8820aff         # ember gold 
LOCK_WRONG_RING=e8820aff	# bright orange
LOCK_RING_WRONG=e8820aff    # bright orange
LOCK_TIME=d4cfe0ff          # silver white
LOCK_TIME_COLOR=d4cfe0ff    # silver white
LOCK_DATE=a09aacff          # muted silver
LOCK_DATE_COLOR=a09aacff    # muted silver
LOCK_LAYOUT=d4cfe0ff		# silver white
LOCK_LAYOUT_COLOR=d4cfe0ff  # silver white
LOCK_VERIF_COLOR=5a1a2aff   # dark crimson
LOCK_WRONG_COLOR=e8820aff   # ember gold
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=d4cfe0ff			# silver white
LOCK_RINGCLEAR=5a1a2aff     # dark crimson
LOCK_INSIDECLEAR=0d0a0ecc	# near black
LOCK_BG=0d0a0e              # no alpha
LOCK_BLUR="0x12"			# blur intensity
