# ============================================================
# Nord
# ------------------------------------------------------------
# Neutral Greys and Blue Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="nord"
GTK_THEME="Nord"
ICON_THEME="Nordzy"
GTK_CSS="$HOME/.config/i3/themes/nord/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/nord/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/nord/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/nord.png"
CALCURSE_THEME="cyan"
BTOP_THEME="nord"


# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="NORD_THEME.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/nord/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="nord.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#2e3440"							          # dark grey purple
DUNST_FG="#eceff4"							          # off white
DUNST_FRAME="#88c0d0"						          # pale blue grey
DUNST_LOW_BG="#242933"					    	    # dark blue black
DUNST_LOW_FG="#7b88a1"					    	    # pale blue grey
DUNST_LOW_FRAME="#4c566a"				    	    # pale light blue grey
DUNST_CRITICAL_BG="#bf616a"				  	    # pale red pink
DUNST_CRITICAL_FG="#eceff4"					      # off white
DUNST_CRITICAL_FRAME="#d08770"				    # pale orange
DUNST_FONT="JetBrainsMono Nerd Font 10"		# Nerd Fonts




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=2e3440cc        	            # dark grey purple
LOCK_RING=88c0d0ff                      	# pale blue
LOCK_KEY=81a1c1ff                       	# pale blue
LOCK_BACKSPACE=bf616aff     	            # pale red
LOCK_VER=a3be8cff           	            # sage green
LOCK_VER_RING=a3be8cff			              # sage green
LOCK_WRONG=bf616aff				                # bright blue purple
LOCK_WRONG_RING=bf616aff		              # pale red
LOCK_TIME=e5e9f0ff          	            # off white
LOCK_DATE=d8dee9ff          	            # off white light grey
LOCK_LAYOUT=eceff4ff        	            # off white
LOCK_SEPARATOR=00000000			              # flat black
LOCK_LINE=00000000				                # flat black
LOCK_TEXT=eceff4ff				                # off white
LOCK_RINGCLEAR=5e81acff     	            # muted blue grey
LOCK_INSIDECLEAR=2e3440cc		              # dark grey purple
LOCK_BG=2e3440ff				                  # dark slate grey
LOCK_BLUR="0x12"				                  # blur intensity
