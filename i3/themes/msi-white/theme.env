# ============================================================
# MSI White
# ------------------------------------------------------------
# Light Grey, Teal, and Lavender Blue Theme
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="msi-white"
GTK_THEME="Adwaita"
ICON_THEME="Papirus-Light"
GTK_CSS="$HOME/.config/i3/themes/msi-white/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/msi-white/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/msi-white/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/msi-white.png"
CALCURSE_THEME="cyan"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="MSI_WHITE.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/msi-white/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="msi-white.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#f0f2f5"							# light grey white
DUNST_FG="#2c3a4a"							# dark blue grey text
DUNST_FRAME="#5bbfcc"						# teal cyan
DUNST_LOW_BG="#e4e8ed"						# soft grey
DUNST_LOW_FG="#7a8fa3"						# muted blue grey
DUNST_LOW_FRAME="#b0bec8"					# light steel blue
DUNST_CRITICAL_BG="#e05a6a"					# rose red
DUNST_CRITICAL_FG="#ffffff"					# white
DUNST_CRITICAL_FRAME="#f0a0a8"				# pale pink
DUNST_FONT="JetBrainsMono Nerd Font 10"		# Nerd Fonts




# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=f0f2f5cc        	# light grey white
LOCK_RING=5bbfccff          	# teal cyan
LOCK_KEY=8b9db5ff           	# steel blue
LOCK_BACKSPACE=e05a6aff     	# rose red
LOCK_VER=7ebfb5ff           	# sage teal
LOCK_VER_RING=7ebfb5ff			# sage teal
LOCK_WRONG=e05a6aff				# rose red
LOCK_WRONG_RING=e05a6aff		# rose red
LOCK_TIME=2c3a4aff          	# dark blue grey
LOCK_DATE=4a5f73ff          	# medium blue grey
LOCK_LAYOUT=2c3a4aff        	# dark blue grey
LOCK_SEPARATOR=00000000			# flat transparent
LOCK_LINE=00000000				# flat transparent
LOCK_TEXT=2c3a4aff				# dark blue grey
LOCK_RINGCLEAR=8b9db5ff     	# steel blue
LOCK_INSIDECLEAR=f0f2f5cc		# light grey white
LOCK_BG=f0f2f5ff				# light grey white
LOCK_BLUR="0x10"				# blur intensity
