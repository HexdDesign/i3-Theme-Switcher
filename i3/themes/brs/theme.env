# ============================================================
# BRS - ( Black Rock Shooter )
# ------------------------------------------------------------
# Black Rock Shooter Theme in Black and Blue
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="brs"
GTK_THEME="Adwaita-dark"
ICON_THEME="Dexy-Color-Dark-Icons"
GTK_CSS="$HOME/.config/i3/themes/brs/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/brs/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/brs/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/brs.png"
CALCURSE_THEME="cyan"
BTOP_THEME="brs"


# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="BRS_THEME.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/brs/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================

STARSHIP_CONFIG="brs.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#0a0e17"						# dark navy blue
DUNST_FG="#cce0f0"						# white slate blue
DUNST_FRAME="#00c8d4"					# cyan
DUNST_LOW_BG="#0d1520"					# navy blue
DUNST_LOW_FG="#5a7a94"					# pale grey blue
DUNST_LOW_FRAME="#1a4a7a"				# dark blue grey
DUNST_CRITICAL_BG="#0d2a4a"				# dark navy blue
DUNST_CRITICAL_FG="#cce0f0"				# white silver blue
DUNST_CRITICAL_FRAME="#1e88e5"			# pale cyan
DUNST_FONT="JetBrainsMono Nerd Font 10"



# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0a0e17cc        # deep navy blue black
LOCK_RING=00c8d4ff          # cyan 
LOCK_KEY=8ab0c8ff           # slate blue
LOCK_KEYHL=8ab0c8ff         # slate blue
LOCK_BACKSPACE=1e88e5ff     # bright blue
LOCK_BSHL=1e88e5ff          # bright blue
LOCK_VER=1a4a7aff           # deep blue
LOCK_VER_RING=1a4a7aff      # deep blue
LOCK_RING_VER=1a4a7aff      # deep blue
LOCK_WRONG=1e88e5ff         # bright blue
LOCK_WRONG_RING=1e88e5ff	# bright blue
LOCK_RING_WRONG=1e88e5ff    # bright blue
LOCK_TIME=cce0f0ff          # near white
LOCK_TIME_COLOR=cce0f0ff    # near white
LOCK_DATE=8ab0c8ff          # slate blue
LOCK_DATE_COLOR=8ab0c8ff    # slate blue
LOCK_LAYOUT=cce0f0ff		# near white
LOCK_LAYOUT_COLOR=cce0f0ff  # near white 
LOCK_VERIF_COLOR=1a4a7aff   # deep blue
LOCK_WRONG_COLOR=1e88e5ff   # bright blue
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=cce0f0ff			# near white
LOCK_RINGCLEAR=1a4a7aff     # deep blue
LOCK_INSIDECLEAR=0a0e17cc	# dark navy blue black
LOCK_BG=0a0e17              # dark navy blue
LOCK_BLUR="0x12"			# blur intensity

