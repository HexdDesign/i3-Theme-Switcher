# ============================================================
# Arch Rain
# ------------------------------------------------------------
# Arch Linux Basic Blue and Grey Theme
# ============================================================
# ============================================================




# ------------------------------------------------------------
# // General //
# ____________________________________________________________
# A General Configuration Control.
# ------------------------------------------------------------
# * GTK - Cross-platform widget toolkit
# * Thunar - File manager for the Xfce Desktop Environment
# * Rofi - A window switcher and application launcher
# * Calcurse - Text-based calendar and scheduling application
# ============================================================

NAME="arch-rain"
GTK_THEME="arch-rain"
ICON_THEME="Vortex-Dark-Icons"
GTK_CSS="$HOME/.config/i3/themes/arch-rain/gtk.css"
GTK4_CSS="$HOME/.config/i3/themes/arch-rain/gtk4.css"
THUNAR_CSS="$HOME/.config/i3/themes/arch-rain/thunar.css"
ROFI_IMAGE="$HOME/.config/rofi/images/arch-rain.png"
CALCURSE_THEME="blue"



# ------------------------------------------------------------
# // Geany //
# ____________________________________________________________
# IDE and text editor
# ============================================================

GEANY_SCHEME="ARCH_RAIN.conf"
GEANY_AUTORELOAD="notify"
GEANY_CSS="$HOME/.config/i3/themes/arch-rain/geany.css"



# ------------------------------------------------------------
# // Starship //
# ____________________________________________________________
# Cross-shell prompt 
# ============================================================
STARSHIP_CONFIG="arch-rain.toml"



# ------------------------------------------------------------
# // Dunst // 
# ____________________________________________________________
# Notification Daemon
# ============================================================

DUNST_BG="#0d1117"						# dark navy blue
DUNST_FG="#dce8f0"						# near white 
DUNST_FRAME="#1e90d4"					# bright cyan blue
DUNST_LOW_BG="#0a0e14"					# dark navy blue
DUNST_LOW_FG="#4a6070"					# light pale cyan
DUNST_LOW_FRAME="#1c2a38"				# dark slate cyan
DUNST_CRITICAL_BG="#c0392b"				# red
DUNST_CRITICAL_FG="#dce8f0"				# near white 
DUNST_CRITICAL_FRAME="#d4881e"			# bright orange
DUNST_FONT="JetBrainsMono Nerd Font 10"



# ------------------------------------------------------------
# Lock screen (i3lock-color)
# ____________________________________________________________
# Simple custom color screen lock
# ============================================================

LOCK_INSIDE=0d1117cc        # near black blue
LOCK_RING=1e90d4ff          # bright blue
LOCK_KEY=5bb8d4ff           # light cyan
LOCK_BACKSPACE=c0392bff     # red
LOCK_VER=d4881eff           # orange
LOCK_VER_RING=d4881eff		# orange
LOCK_WRONG=c0392bff			# red
LOCK_WRONG_RING=c0392bff	# red
LOCK_TIME=dce8f0ff			# white blue
LOCK_DATE=adc8d8ff			# light pale blue
LOCK_LAYOUT=dce8f0ff		# white blue
LOCK_SEPARATOR=00000000
LOCK_LINE=00000000
LOCK_TEXT=dce8f0ff			# white blue
LOCK_RINGCLEAR=1e6fa0ff		# blue
LOCK_INSIDECLEAR=0d1117cc	# near black 
LOCK_BG=0d1117ff			# near black blue
LOCK_BLUR="0x12"			$ blur intensity
