theme[cpu_mid]="#bd93f9"
theme[cpu_end]="#ff79c6"

# --- Memory ---
theme[mem_box]="#ff79c6"
theme[mem_start]="#ff79c6"
theme[mem_mid]="#bd93f9"
theme[mem_end]="#8be9fd"

# --- Memory detail ---
theme[used_start]="#ff79c6"
theme[used_mid]="#bd93f9"
theme[used_end]="#8be9fd"
theme[available_start]="#8be9fd"
theme[available_mid]="#50fa7b"
theme[available_end]="#f8f8f2"
