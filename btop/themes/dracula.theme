# Pink, Purple, and Grey
# ============================================================
# --- Base ---
theme[main_bg]="#282a36"
theme[main_fg]="#f8f8f2"

# --- Titles / Highlights ---
theme[title]="#bd93f9"
theme[hi_fg]="#ff79c6"
theme[selected_bg]="#44475a"
theme[selected_fg]="#f8f8f2"
theme[inactive_fg]="#6272a4"

# --- Graphs ---
theme[graph_text]="#f8f8f2"
