theme[cached_mid]="#bd93f9"
theme[cached_end]="#ff79c6"
theme[free_start]="#21222c"
theme[free_mid]="#44475a"
theme[free_end]="#6272a4"

# --- Network ---
theme[net_box]="#8be9fd"
theme[net_start]="#8be9fd"
theme[net_mid]="#50fa7b"
theme[net_end]="#bd93f9"

