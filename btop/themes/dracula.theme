theme[download_start]="#8be9fd"
theme[download_mid]="#50fa7b"
theme[download_end]="#bd93f9"
theme[upload_start]="#ff79c6"
theme[upload_mid]="#bd93f9"
theme[upload_end]="#6272a4"

# --- Processes ---
theme[proc_box]="#bd93f9"
